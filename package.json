{
  "name": "hive-mp-publish",
  "version": "0.1.2",
  "description": "Controlled-trial Gateway and CLI for publishing Markdown to WeChat MP drafts",
  "author": "Hive MP Publish contributors",
  "license": "Apache-2.0",
  "keywords": [
    "公众号",
    "markdown",
    "hive",
    "wechat",
    "gateway",
    "publishing",
    "renderer"
  ],
  "type": "module",
  "bin": {
    "hive-mp-publish": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "NOTICE"
  ],
  "homepage": "https://github.com/xavierliang/hive-mp-publish#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xavierliang/hive-mp-publish.git"
  },
  "bugs": {
    "url": "https://github.com/xavierliang/hive-mp-publish/issues"
  },
  "scripts": {
    "build": "tsc",
    "upgrade:core": "pnpm update @wenyan-md/core",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"tests/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "cli": "tsx ./src/cli.ts",
    "cli:bun": "bun ./src/cli.ts",
    "test:bin": "pnpm build && node ./dist/cli.js render -f tests/publish.md -c tests/manhua.css --no-mac-style",
    "test:bun:smoke": "pnpm build && bun scripts/bun-smoke.mjs",
    "test:realPublish": "pnpm build && node ./dist/cli.js publish -f tests/publish.md -t phycat --env-file=.env.test",
    "test:serverPublish": "pnpm build && node ./dist/cli.js publish -f tests/publish.md -c tests/manhua.css --no-mac-style --server http://localhost:3000 --allow-insecure-http --api-key \"$HIVE_MP_API_KEY\" --env-file=.env.test",
    "test:serve": "pnpm build && node ./dist/cli.js serve --env-file=.env.test"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "@inquirer/input": "^5.0.11",
    "@inquirer/password": "^5.0.11",
    "@wenyan-md/core": "^3.0.9",
    "commander": "^14.0.0",
    "express": "^5.2.1",
    "form-data-encoder": "^4.1.0",
    "formdata-node": "^6.0.3",
    "jsdom": "^27.4.0",
    "multer": "^2.1.0",
    "undici": "^8.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
